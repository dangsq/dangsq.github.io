    <div id="app">
        <div class="markdown-section" style="margin-top: 0; padding-top: 0; padding-bottom: 0;">
             <div class="window-title-bar">
                <span>[A:\\] MY_FOLDER\INDEX.HTML</span>
                <div class="window-controls">
                    <button style="font-weight: bold;">_</button>
                    <button style="font-weight: bold;">□</button>
                    <button style="background-color: #ff3333; color: white; font-weight: bold;">X</button>
