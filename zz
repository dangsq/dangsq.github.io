<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shengqi Dang - Millenium Dream</title>
    <link rel="icon" href="./1F34E.svg">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet"> 
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">
    
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0">
    <link rel="stylesheet" href="//cdn.jsdelivr.net/npm/docsify@4/lib/themes/vue.css">
    
    <style>
        /* --- 核心 Y2K / Win98 变量 --- */
        :root {
            --bg-main: #eff0eb; /* Win98 经典灰色/米白 */
            --bg-deep: #283747; /* 底部深蓝/科技蓝 */
            --y2k-blue: #008080; /* Win98 任务栏/标题蓝 (Teal) */
            --y2k-mint: #00ffcc; /* 薄荷绿/科技感点缀 */
            --y2k-pink: #ff69b4; /* 暖粉/少女感点缀 */
            --y2k-orange: #ff9900; /* 暖橙/数字感点缀 */
            --text-dark: #1f1f1f;
            --text-light: #ffffff;
            
            /* 窗口面板变量 (拟物化) */
            --panel-bg: #ffffff; /* 纯白内容区 */
            --panel-border-light: #ffffff;
            --panel-border-dark: #4b4b4b;
            --panel-shadow-deep: rgba(0, 0, 0, 0.4);
        }

        /* --- 全局基础 --- */
        body {
            background-color: var(--bg-main);
            min-height: 100vh;
            margin: 0;
            padding: 0;
            font-family: 'Merriweather', serif;
            color: var(--text-dark);
            overflow-x: hidden;
            /* 模拟 CRT 边缘渐变 */
            box-shadow: inset 0 0 100px rgba(0, 0, 0, 0.1);
        }

        ::-webkit-scrollbar { width: 12px; }
        ::-webkit-scrollbar-track { background: var(--bg-main); }
        ::-webkit-scrollbar-thumb { 
            background: var(--y2k-blue); 
            border: 3px solid var(--bg-main); /* 制造立体感 */
            box-shadow: inset 1px 1px var(--text-light), inset -1px -1px var(--panel-border-dark);
        }
        ::selection { background: var(--y2k-pink); color: #fff; text-shadow: none; }

        /* --- 背景视觉层 (Low-Poly / Y2K) --- */

        /* 1. 低多边形 3D 水面/地形 (替换网格) */
        .lowpoly-water {
            position: fixed; bottom: 0; left: 0; width: 100%; height: 50vh;
            background: 
                repeating-linear-gradient(45deg, rgba(0, 255, 204, 0.2) 0, rgba(0, 255, 204, 0.2) 2px, transparent 2px, transparent 10px),
                linear-gradient(to bottom, transparent, var(--bg-deep));
            transform: perspective(400px) rotateX(70deg) translateY(20vh);
            z-index: -5;
            opacity: 0.8;
            filter: drop-shadow(0 0 10px rgba(0, 255, 204, 0.2));
            animation: waterMove 15s linear infinite alternate;
        }
        @keyframes waterMove { 0% { opacity: 0.8; transform: perspective(400px) rotateX(70deg) translateY(20vh) translateX(0); } 100% { opacity: 0.9; transform: perspective(400px) rotateX(70deg) translateY(20vh) translateX(10%); } }

        /* 2. 抽象 Y2K 几何体 */
        .y2k-shape {
            position: fixed;
            z-index: -4;
            opacity: 0.7;
            transform-style: preserve-3d;
            animation: floatShape 10s infinite ease-in-out alternate;
        }
        /* 橙色低多边形球体 */
        .y2k-shape.sphere {
            top: 15%; right: 10%; width: 100px; height: 100px;
            background: radial-gradient(circle, var(--y2k-orange) 0%, transparent 70%);
            border-radius: 50%;
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); /* 模拟低多边形 */
        }
        /* 粉色低多边形甜甜圈/圆环 */
        .y2k-shape.donut {
            bottom: 20%; left: 5%; width: 120px; height: 120px;
            border: 15px solid var(--y2k-pink);
            border-radius: 50%;
            box-shadow: 0 0 20px rgba(255, 105, 180, 0.5);
            animation: floatShape 12s infinite linear alternate-reverse;
        }

        @keyframes floatShape {
            0% { transform: translate(0, 0) rotate(0deg); }
            100% { transform: translate(50px, -20px) rotate(360deg); }
        }

        /* --- 内容样式 (Win98/拟物化窗口) --- */
        .markdown-section {
            max-width: 900px;
            margin: 50px auto;
            padding: 20px !important;
            
            /* Win98 窗口样式 */
            background-color: var(--panel-bg);
            border-top: 2px solid var(--panel-border-light);
            border-left: 2px solid var(--panel-border-light);
            border-bottom: 2px solid var(--panel-border-dark);
            border-right: 2px solid var(--panel-border-dark);
            box-shadow: 4px 4px var(--panel-shadow-deep); /* 深度阴影 */
            position: relative;
            z-index: 5;
            min-height: 70vh;
        }

        /* 标题栏模拟 */
        .window-title-bar {
            background-color: var(--y2k-blue);
            color: var(--text-light);
            font-family: 'Press Start 2P', cursive;
            font-size: 10px;
            padding: 5px 10px;
            margin: -20px -20px 20px -20px; /* 扩展到窗口边缘 */
            border-bottom: 2px solid var(--panel-border-dark);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .window-controls {
            display: flex; gap: 4px;
        }
        .window-controls button {
            width: 16px; height: 16px;
            background-color: var(--bg-main);
            border: 1px solid #000;
            font-size: 10px;
            line-height: 14px;
            text-align: center;
            cursor: pointer;
            box-shadow: inset -1px -1px var(--text-dark), inset 1px 1px var(--text-light);
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Orbitron', sans-serif; /* 科技感/未来感字体 */
            color: var(--y2k-blue);
            text-shadow: 2px 2px 0px rgba(0, 0, 0, 0.1);
            margin-top: 1.5em;
        }
        
        h1 {
            color: var(--y2k-pink);
            font-size: 2.5rem;
            text-shadow: 3px 3px 0px rgba(0, 0, 0, 0.15);
            border-bottom: 2px solid var(--y2k-mint);
            padding-bottom: 10px;
        }

        p, li, span, div {
            color: var(--text-dark);
            font-weight: 400; 
            line-height: 1.7;
            letter-spacing: 0.2px;
        }

        .markdown-section a {
            color: var(--y2k-orange);
            text-decoration: none;
            font-weight: bold;
            border-bottom: 1px dashed var(--y2k-orange);
            transition: color 0.2s;
        }
        .markdown-section a:hover {
            color: var(--y2k-pink);
            border-bottom: 1px dashed var(--y2k-pink);
        }

        /* 导航栏 (任务栏/菜单栏模拟) */
        .nav-container {
            margin-bottom: 20px;
        }
        .nav-container ul {
            background: var(--bg-main);
            border: 2px solid var(--panel-border-dark);
            border-bottom: 2px solid var(--text-light);
            border-right: 2px solid var(--text-light);
            padding: 2px;
            display: inline-flex;
            list-style-type: none;
            box-shadow: 2px 2px var(--panel-shadow-deep);
        }
        .nav-container li {
            font-family: 'Press Start 2P', cursive;
            font-size: 8px !important;
            color: var(--text-dark) !important;
            padding: 8px 12px;
            text-transform: uppercase;
            letter-spacing: 0;
            margin: 1px;
            cursor: pointer;
            transition: all 0.1s;
        }
        .nav-container li:hover {
            background: var(--y2k-blue);
            color: var(--text-light) !important;
            box-shadow: inset 1px 1px var(--text-light), inset -1px -1px var(--text-dark); /* 模拟按下状态 */
            transform: translate(1px, 1px);
        }
        .nav-container a {
            text-decoration: none;
        }
        
        /* 标题文字样式调整 */
        .top-title {
            font-family: 'Press Start 2P', cursive;
            font-size: 14px !important;
            color: var(--y2k-pink) !important;
            padding: 8px 12px;
            border: 2px solid var(--y2k-pink);
            background: var(--text-light);
            box-shadow: 4px 4px var(--panel-shadow-deep);
            transition: all 0.3s;
        }
        .top-title:hover {
            transform: rotate(5deg) scale(1.1);
        }

        /* Glitch 文本 (调整为 Y2K 风格) */
        .glitch-text {
            font-family: 'Orbitron', sans-serif;
            color: var(--text-dark);
            font-size: 30pt;
            position: relative;
            text-shadow: 2px 2px 0px var(--y2k-mint);
        }
        .glitch-text::before, .glitch-text::after {
            content: attr(data-text);
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            color: var(--y2k-pink);
            text-shadow: -2px -2px 0px var(--y2k-orange);
            background: none;
        }
        /* 移除复杂的 CRT 扫描线和 glitch 动画，仅保留颜色偏移 */
        .glitch-text::before { z-index: -1; left: 3px; top: 3px; }
        .glitch-text::after { z-index: -2; left: -3px; top: -3px; }

        /* Typing 动画调整 */
        .typing-text {
            display: inline-block; 
            font-family: 'Press Start 2P'; 
            font-size: 25pt; 
            color: var(--y2k-blue); 
            border-right: 5px solid var(--y2k-mint); 
            padding-right: 10px; 
            animation: typing 1.5s steps(10) infinite alternate; 
            text-shadow: 2px 2px 0px rgba(0,0,0,0.1);
        }

        @keyframes typing {
            0%, 100% { border-color: var(--y2k-mint); }
            50% { border-color: transparent; }
        }

        /* 项目卡片 (Project Card) 拟物化 */
        .project {
            background-color: var(--bg-main);
            border-top: 2px solid var(--text-light);
            border-left: 2px solid var(--text-light);
            border-bottom: 2px solid var(--panel-border-dark);
            border-right: 2px solid var(--panel-border-dark);
            padding: 15px;
            margin: 30px 0;
            position: relative;
            overflow: hidden;
            box-shadow: 2px 2px var(--panel-shadow-deep);
            transition: all 0.1s;
        }
        .project:hover {
            /* 模拟鼠标悬停时的轻微抬起效果 */
            transform: translate(-1px, -1px);
            box-shadow: 4px 4px var(--panel-shadow-deep);
        }

        .project-title {
            background-color: var(--y2k-mint);
            color: var(--text-dark);
            font-family: 'Orbitron', sans-serif;
            font-size: 1.2rem;
            padding: 5px 10px;
            margin: -15px -15px 15px -15px;
            text-transform: uppercase;
            border-bottom: 2px solid var(--panel-border-dark);
            box-shadow: 1px 1px 0px rgba(0, 0, 0, 0.2);
        }
        .project-title h3 {
            margin: 0;
            color: var(--text-dark);
            text-shadow: none;
            font-size: 1.2rem;
        }

        .project-summary span {
            display: inline-block;
            background: var(--bg-main);
            border: 2px solid var(--y2k-orange);
            color: var(--y2k-orange);
            font-family:'Press Start 2P', cursive;
            font-size: 0.7rem;
            padding: 4px 6px;
            margin-right: 5px;
            margin-bottom: 5px;
            border-radius: 0;
            box-shadow: 1px 1px 0px rgba(0, 0, 0, 0.2);
        }

        .project-details {
            height: 0;
            overflow: hidden;
            opacity: 0;
            visibility: hidden;
            transition: height 0.4s ease, opacity 0.4s ease, margin-top 0.4s ease;
            margin-top: 0;
            border-top: 1px solid transparent;
        }
        .project-details.open {
            opacity: 1;
            visibility: visible;
            margin-top: 20px;
            padding-top: 10px;
            border-top: 1px dashed var(--y2k-blue);
        }

        .project-toggle {
            /* 模拟 Win98 按钮 */
            background-color: var(--bg-main);
            border-top: 2px solid var(--text-light);
            border-left: 2px solid var(--text-light);
            border-bottom: 2px solid var(--panel-border-dark);
            border-right: 2px solid var(--panel-border-dark);
            color: var(--text-dark);
            font-family: 'Press Start 2P', cursive;
            font-size: 0.6rem;
            padding: 8px 12px;
            cursor: pointer;
            transition: all 0.1s;
            margin-top: 10px;
            text-transform: uppercase;
        }
        .project-toggle:hover {
            /* 悬停时无变化，模拟 Win98 风格 */
            background-color: var(--bg-main);
        }
        .project-toggle:active {
            /* 模拟按下状态 */
            border-top: 2px solid var(--panel-border-dark);
            border-left: 2px solid var(--panel-border-dark);
            border-bottom: 2px solid var(--text-light);
            border-right: 2px solid var(--text-light);
            transform: translate(1px, 1px);
            box-shadow: none;
        }
        
        .sidebar-toggle { display: none !important; }

        /* 图片样式 (Low-Poly 边框) */
        .markdown-section img {
            border: 4px solid var(--y2k-blue);
            outline: 2px solid var(--y2k-mint);
            box-shadow: 6px 6px 0px rgba(0, 0, 0, 0.3);
            border-radius: 0;
            max-width: 100%;
            transition: transform 0.3s ease;
            filter: grayscale(0.1) contrast(1.1);
        }
        .markdown-section img:hover {
            transform: scale(1.03) rotate(-1deg);
            box-shadow: 8px 8px 0px var(--y2k-pink);
            border-color: var(--y2k-pink);
        }

    </style>
</head>
<body>
    
